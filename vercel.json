{
  "version": 2,
  "builds": [
    {
      "src": "app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "app/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "app/favicon.svg"
    },
    {
      "src": "/icons.svg",
      "dest": "app/icons.svg"
    },
    {
      "src": "/(.*)",
      "dest": "app/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "node_modules/sql.js/dist/sql-wasm.wasm"
    }
  }
}
